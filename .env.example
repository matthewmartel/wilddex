# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and never committed.

# Supabase (https://supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox access token (https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Anthropic API key for AI animal identification (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Public base URL of the running site (use http://localhost:3000 for local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin access (comma-separated). Optional for local use.
WILDDEX_ADMIN_EMAILS=
WILDDEX_ADMIN_USER_IDS=
